{
  "expo": {
    "name": "Memora English",
    "slug": "my-app-new",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./my-app-new/assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./my-app-new/assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111827"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.memora.myapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleLocalizations": ["en", "fr", "ru", "es", "de"],
        "CFBundleDevelopmentRegion": "Base"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./my-app-new/assets/adaptive-icon.png",
        "backgroundColor": "#5c39c9"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.myapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-notifications",
      "./plugins/withLocalizedInfoPlist",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "supportsScreens": {
              "small": true,
              "normal": true,
              "large": false,
              "xlarge": false
            }
          },
          "ios": {
            "infoPlist": {
              "CFBundleLocalizations": ["en", "fr", "ru", "es", "de"],
              "CFBundleDevelopmentRegion": "Base"
            }
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "07af34ec-68d4-4d38-a621-0946726a8191"
      },
      "IAP_PRODUCTS": {
        "WEEKLY": "weekly",
        "YEARLY": "yearly"
      },
      "IAP_SHARED_SECRET": "ebe3cfdb3fcb45e88d39b77fa204b185"
    }
  }
}
